# Copy to .env.local after running: vercel env pull .env.local
PGHOST=
PGPORT=5432
PGUSER=
PGDATABASE=postgres
AWS_REGION=
AWS_ROLE_ARN=
VERCEL_OIDC_TOKEN=

# Bedrock — use a separate AWS account (e.g. your root account) for vision
BEDROCK_AWS_ACCESS_KEY_ID=
BEDROCK_AWS_SECRET_ACCESS_KEY=
BEDROCK_AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# Rate limiting (Upstash Redis — required for production on Vercel)
# Create a free database at https://upstash.com and add via Vercel integration
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
